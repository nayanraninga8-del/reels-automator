# ─── Anthropic (Claude AI) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Instagram Graph API ──────────────────────────────────────────
IG_ACCOUNT_ID=your_instagram_business_account_id
IG_ACCESS_TOKEN=your_long_lived_access_token

# ─── Content settings ─────────────────────────────────────────────
# Your content niche — be specific for better AI output
NICHE=motivation and personal growth

# Target audience for caption tone
AUDIENCE=young Indians aged 18-30

# ─── Video files ──────────────────────────────────────────────────
# Local folder where you drop your daily video files
VIDEOS_FOLDER=./videos

# Public URL where Instagram can fetch your videos
# Options: AWS S3, Cloudinary, your own server, etc.
# Example: https://your-bucket.s3.ap-south-1.amazonaws.com/videos
PUBLIC_VIDEO_BASE_URL=https://your-public-url.com/videos

# ─── Schedule ─────────────────────────────────────────────────────
# Cron format: "minute hour * * *"  (UTC time)
# 6:00 PM IST = 12:30 UTC  →  "30 12 * * *"
# 9:00 AM IST = 3:30 UTC   →  "30 3 * * *"
# 8:00 PM IST = 14:30 UTC  →  "30 14 * * *"
CRON_SCHEDULE=30 12 * * *
